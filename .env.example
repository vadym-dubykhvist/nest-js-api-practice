# Copy this to .env and fill in your own values.
# .env is gitignored — never commit real secrets.

# Postgres (used by docker-compose for the dev DB and the app container)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# JWT signing secret (used by the app)
JWT_SECRET=

# Optional overrides for running the app outside of docker
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_SYNCHRONIZE=false
DB_DROP_SCHEMA=false
